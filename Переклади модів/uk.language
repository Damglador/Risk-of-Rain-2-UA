        //[MISC]
        "MYSTICSITEMS_STATCHANGE_LIST_HEADER": "Поточна зміна характеристик:",
        "MYSTICSITEMS_STATCHANGE_LIST_MAXHEALTH": "{0}% макс. здоров'я",
        "MYSTICSITEMS_STATCHANGE_LIST_REGEN": "{0}% регенерації здоров'я",
