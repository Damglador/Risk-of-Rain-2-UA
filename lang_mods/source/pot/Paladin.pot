#: .uk.PALADIN_SPECIAL_SCEPSUN_NAME
msgctxt ".uk.PALADIN_SPECIAL_SCEPSUN_NAME"
msgid "Pride Flare"
msgstr ""

#: .uk.PALADIN_SPECIAL_SCEPSUN_DESCRIPTION
