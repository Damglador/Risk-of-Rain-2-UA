msgstr ""

#: .uk.PALADIN_PRIMARY_CURSESLASH_NAME
msgid "Accursed Blade"
msgstr ""

#: .uk.PALADIN_PRIMARY_CURSESLASH_DESCRIPTION
msgid ""
"Slash for <style=cIsDamage>380% damage</style>. Fires a <style=cIsUtility>"
"beam of light</style> for <style=cIsDamage>300% damage</style> if the "
