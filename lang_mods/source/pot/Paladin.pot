msgstr ""

#: .uk.PALADIN_PRIMARY_SLASH_NAME
msgid "Divine Blade"
msgstr ""

#: .uk.PALADIN_PRIMARY_SLASH_DESCRIPTION
msgid ""
"Slash for <style=cIsDamage>300% damage</style>. Fires a <style=cIsUtility>"
