#: .strings.ITEM_CHARONS_OBOL_NAME
msgid "Charon's Obol"
msgstr ""

#: .strings.ITEM_CHARONS_OBOL_DESCRIPTION
msgid ""
"- Reduces <color=\"yellow\">revival time</color>. \n"
"- Can be consumed for <color=\"yellow\">instant</color> revival without "
"Death Curse. \n"
"- <color=\"yellow\">Removes</color> additional <color=\"red\">Death Curse</"
"color> on stage change.\n"
"- Increase <color=\"yellow\">range</color> and decrease <color=\"yellow\">"
"damage</color> for your revival."
msgstr ""

#: .strings.ITEM_CHARONS_OBOL_PICKUP
msgid "Makes revival easier. Can be consumed for instant revival."
msgstr ""

#: .strings.ITEM_REVIVE_EVERYWHERE_NAME
