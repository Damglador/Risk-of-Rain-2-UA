    "ACHIEVEMENT_ENFORCER_DESPERADOUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Граючи за Силовика, здолайте унікальну вартову Золотавого берегу, скинувши її за мапу.",
    "ACHIEVEMENT_ENFORCER_BUNGUSUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Силовик: Довершеність",
    "ACHIEVEMENT_ENFORCER_BUNGUSUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Граючи за Силовика, станьте одним цілим із жвагрибцями.",
    "ACHIEVEMENT_ENFORCER_STORMTROOPERUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Силовик: Хай живе імперія",
    "ACHIEVEMENT_ENFORCER_STORMTROOPERUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Граючи за Силовика, здолайте елітний блок керування Солусу.",
    "ACHIEVEMENT_ENFORCER_FROGUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Силовик: Через товсте й тонке",
    "ACHIEVEMENT_ENFORCER_FROGUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Граючи за Силовика, знайдіть друга на Місяці.",
    "ACHIEVEMENT_ENFORCER_STEVEUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Силовик: Блоки",
    "ACHIEVEMENT_ENFORCER_STEVEUNLOCKABLE_ACHIEVEMENT_ID_DESCRIPTION": "Граючи за Силовика, заблокуйте атаку щитом.",
    "ENFORCER_STEVEUNLOCKABLE_UNLOCKABLE_NAME": "Силовик: Блоки",
    "ENFORCER_PRIMARY_SHOTGUN_NAME_UPGRADE_DESCRIPTION": "<style=cIsUtility>+5%</style> шкоди, <style=cIsUtility>+10%</style> товщини кулі та <style=cIsUtility>+0.1</style> розкиду куль",
    "ENFORCER_PROC_BULLET": "Куля",
    "ENFORCER_PROC_HAMMER": "Молот",
    "ENFORCER_PROC_GRENADE": "Граната",
    "ENFORCER_PROC_DAMAGING_GAS": "Отруйний газ",
    "ENFORCER_PROC_SKATEBOARD": "Стейтборд",
    "NEMFORCER_NAME": "Злостивий Силовик",
    "NEMFORCER_DESCRIPTION": "Злостивий Силовик - це втілення доблесті та сили, надприродний тип, якого не можна сприймати легковажно.<color=#CCD3E0>\r\n\r\n< ! > Золотий молот може вразити відразу багатьох ворогів.\r\n\r\n< ! > Використовуйте Панування з висоти, щоб виконати нищівний удар.\r\n\r\n< ! > Стрільба із Золотого мінігана - ключ до знищення потужних босів.\r\n\r\n< ! > Щити - для сцикунів.\r\n</style>\r\n",
    "NEMFORCER_SUBTITLE": "Непідкупна тінь",
    "NEMFORCER_LORE": "\nХеві з Team Fortress 2\n\n",
    "NEMFORCER_OUTRO_FLAVOR": "...і він пішов, з новознайденою силою вшанування.",
    "NEMFORCER_BOSS_NAME": "Ультра Злостивий Силовик",
    "NEMFORCER_BOSS_SUBTITLE": "Кінець лінії",
    "DEDEDE_NAME": "King Dedede",
    "DEDEDE_BOSS_SUBTITLE": "Король країни мрій",
    "ENFORCER_EVENT_NEMFORCERBOSS_START": "З порожнечі виходить неприродна сила... </style>",
    "ENFORCER_EVENT_NEMFORCERBOSS_END": "Вплив порожнечі зникає...</style>",
    "NEMFORCER_PASSIVE_NAME": "Колос",
    "NEMFORCER_PASSIVE_DESCRIPTION": "Злостивий Силовик отримує <style=cIsHealing>бонусну регенерацію здоровя</style>, базуючись на <style=cIsHealth>відсутньому здоров'ї</style>, до <style=cIsHealth>2,5% макс. здоров'я</style>.",
    "NEMFORCER_PASSIVE_REWORK_DESCRIPTION": "Злостивий Силовик регенерує <style=cIsHealing>2%</style> від <style=cIsHealing>макс. здоров'я</style> протягом 3с після вдаряння ворога <style=cIsDamage>атакою ближнього бою</style>.",
    "NEMFORCER_PRIMARY_HAMMER_NAME": "Золотий молот",
    "NEMFORCER_PRIMARY_HAMMER_DESCRIPTION": "Змахує молотом, завдаючи <style=cIsDamage>500% шкоди</style>.",
    "NEMFORCER_PRIMARY_THROWHAMMER_NAME": "Метальний молот",
    "NEMFORCER_PRIMARY_THROWHAMMER_DESCRIPTION": "Кидає молот, завдаючи <style=cIsDamage>620% шкоди</style>.",
    "NEMFORCER_PRIMARY_MINIGUN_NAME": "Золотий мініґан",
    "NEMFORCER_PRIMARY_MINIGUN_DESCRIPTION": "Розкручує кулемет Гатлінга та стріляє градом куль, що завдають <style=cIsDamage>65% шкоди</style> кожна. <style=cIsUtility>Сповільнює вас під час стрільби.</style>",
    "KEYWORD_SLAM": "<style=cKeywordName>Удар вниз</style><style=cIsDamage>Приголомшення.</style> Злісно <style=cIsHealth>б'є об землю</style> молотом, завдаючи <style=cIsDamage>300%-2500% шкоди</style> та додаткові <style=cIsDamage>30%</style> хвилею. <style=cIsUtility>Радіус охоплення хвилі збільшується зі швидкістю.</style>",
    "NEMFORCER_SECONDARY_BASH_NAME": "Панування",
    "NEMFORCER_SECONDARY_BASH_DESCRIPTION": "<style=cIsUtility>Заряджає</style> та виконує <style=cIsDamage>зростальний аперкот</style>, що завдає <style=cIsDamage>450%-2500% шкоди</style>. Використання під час <style=cIsUtility>падіння та погляду донизу</style> виконує <style=cIsUtility>Удар вниз</style>.",
    "NEMFORCER_SECONDARY_SLAM_NAME": "Панування (Мініґан)",
    "NEMFORCER_SECONDARY_SLAM_DESCRIPTION": "<style=cIsDamage>Приголомшує.</style> Під час кулеметного режиму, жорстко <style=cIsHealth>вдаряє</style> молотом об землю, завдаючи <style=cIsDamage>600% шкоди</style> та <style=cIsDamage>відкидаючи</style> ворогів. <style=cIsUtility>Підриває снаряди.</style>",
    "NEMFORCER_UTILITY_GAS_NAME": "Граната XM47",
    "NEMFORCER_UTILITY_GAS_DESCRIPTION": "Кидає гранату, що вибухає створюючи хмару <style=cIsUtility>корозійного газу</style>, що <style=cIsUtility>сповільнює</style> та завдає <style=cIsDamage>200% шкоди за секунду</style>, та триває <style=cIsDamage>16 секунд</style>.",
    "NEMFORCER_UTILITY_JUMP_NAME": "Super Dedede Jump",
    "NEMFORCER_UTILITY_JUMP_DESCRIPTION": "Підстрибує в повітря та вдаряє по землі, завдаючи <style=cIsDamage>3200% шкоди</style>. <style=cIsUtility>Завдає менше шкоди далі від центру.</style>",
    "KEYWORD_GRAPPLE": "<style=cKeywordName>Захоплення</style><style=cSub>Накладає <style=cIsDamage>приголомшення</style> та намагається <style=cIsUtility>захопити</style> ворога поблизу.",
    "NEMFORCER_UTILITY_CRASH_NAME": "Теплі обійми",
    "NEMFORCER_UTILITY_CRASH_DESCRIPTION": "<style=cIsUtility>Захоплює.</style> Підстрибує в повітря та вдаряє по землі, завдаючи <style=cIsDamage>2400% шкоди</style>. <style=cIsUtility>Завдає менше шкоди далі від центру.</style>",
    "NEMFORCER_SPECIAL_MINIGUNUP_NAME": "Позиція придушення",
    "NEMFORCER_SPECIAL_MINIGUNUP_DESCRIPTION": "Займає наступальну позицію, <style=cIsDamage>підготовляючи кулемет</style>. <style=cIsHealth>Не дає бігати</style>.",
    "NEMFORCERBODY_DEFAULT_SKIN_NAME": "Злостивий",
    "NEMFORCERBODY_ENFORCER_SKIN_NAME": "Силовик",
    "NEMFORCERBODY_CLASSIC_SKIN_NAME": "Класичний",
    "NEMFORCERBODY_TYPHOON_SKIN_NAME": "Чемпіон",
    "NEMFORCERBODY_DRIP_SKIN_NAME": "Прикид",
    "NEMFORCERBODY_DEDEDE_SKIN_NAME": "King Dedede",
    "NEMFORCERBODY_MINECRAFT_SKIN_NAME": "Minecraft",
    "ACHIEVEMENT_ENFORCER_NEMESIS2UNLOCKABLE_ACHIEVEMENT_ID_NAME": "???",
    "ACHIEVEMENT_NEMFORCER_MASTERYUNLOCKABLE_ACHIEVEMENT_ID_NAME": "Злостивий Силовик: Майстерність",
