#: .uk.INFINITETOWER_SUDDEN_DEATH
msgid "<style=cWorldEvent>[WARNING] The Focus begins to falter..</style>"
msgstr "<style=cWorldEvent>[УВАГА] Фокус починає звужуватися...</style>"

#: .uk.INFINITETOWER_OBJECTIVE_AWAITINGACTIVATION
msgid "Activate the <style=cIsVoid>Focus</style>"
msgstr "Активувати <style=cIsVoid>Фокус</style>"

#: .uk.INFINITETOWER_OBJECTIVE_TRAVEL
msgid "Follow the <style=cIsVoid>Focus</style>"
msgstr "Слідувати за <style=cIsVoid>Фокусом</style>"

#: .uk.INFINITETOWER_OBJECTIVE_PORTAL
msgid "Advance through the <style=cIsVoid>Infinite Portal</style>"
msgstr "Пройти крізь <style=cIsVoid>Нескінченний портал</style>"

#: .uk.INFINITETOWER_OBJECTIVE_AWAITING_TRAVEL
msgid "Awaiting permission to travel."
msgstr "Очікування дозволу на пересування."

#: .uk.INFINITETOWER_TRAVEL_NOTICE
msgid "<style=cWorldEvent>The focus awaits input to travel further.</style>"
msgstr ""
"<style=cWorldEvent>Фокус очікує на команду, щоб почати рухатись.</style>"

#: .uk.INFINITETOWER_TRAVEL_CONTEXT
msgid "Begin travelling"
msgstr "Почати пересування"

#: .uk.PORTAL_ITEND_NAME
msgid "Simulated Exit Rift"
msgstr "Розкол завершення симуляції"

#: .uk.PORTAL_ITEND_CONTEXT
msgid "End Simulation?"
msgstr "Завершити симуляцію?"

#: .uk.OBJECTIVE_ITEND
msgid "Continue or end the <style=cIsVoid>Simulation</style>"
msgstr "Продовжити або завершити <style=cIsVoid>симуляцію</style>"

#: .uk.ARTIFACT_AUGMENTS_NAME
msgid "Artifact of Augments"
msgstr "Артефакт вкраплень"

#: .uk.ARTIFACT_AUGMENTS_DESCRIPTION
msgid "All waves will be augmented waves."
msgstr "Усі хвилі матимуть випадкові вкраплення."

#: .uk.ARTIFACT_NORMALSTAGES_NAME
msgid "Artifact of Reality"
msgstr "Артефакт реальності"

#: .uk.ARTIFACT_NORMALSTAGES_DESCRIPTION
msgid ""
"Void versions of any stage may be used instead of only Simulacrum stage "
"variants."
msgstr ""
"Замість лише варіантів етапів Симулякру, можуть бути використані мапи всіх "
"етапів."

#: .uk.ARTIFACT_SIMUDRONES_NAME
msgid "Artifact of Ingenuity"
msgstr "Артефакт винахідливості"

#: .uk.ARTIFACT_SIMUDRONES_DESCRIPTION
msgid ""
"Broken drones, drone related interactables and items are allowed to spawn. "
"Drones are immune to Void Fog."
msgstr ""
"Дозволяє з'являтись зламаним дронам і об'єктам взаємодії та предметам, що "
"пов'язані з дронами. Дрони не отримують шкоди від туману Порожнечі."

#: .uk.HORROR_BODY_NAME
msgid "Unknown Horror"
msgstr "Незвіданий жах"

#: .uk.GIANTGUP_BODY_NAME
msgid "Guap"
msgstr "Ґуап"

#: .uk.UNLOCKABLE_LOG_GIANTGUP
msgid "Monster Log: Guap"
msgstr "Запис про монстра: Ґуап"

#: .uk.SUPERMEGACRAB_BODY_NAME
msgid "Deepend Void Devastator"
msgstr "Глибинний руйнівник Порожнечі"

#: .uk.UNLOCKABLE_LOG_SUPERMEGACRAB
msgid "Monster Log: Deepend Void Devastator"
msgstr "Запис про монстра: Глибинний руйнівник Порожнечі"

#: .uk.COST_VOIDCOINBLOOD_FORMAT
msgid ""
"<color=#FF349F><sprite name=\"VoidCoin\" tint=1>1 or <color=#DA1D1D>{0}% HP</"
"color></color>"
msgstr ""
"<color=#FF349F><sprite name=\"Монета Порожнечі\" tint=1>1 or <color=#DA1D1D>"
"{0}% ОЗ</color></color>"

#: .uk.INFINITETOWER_WAVE_DESCRIPTION_BOSS_BROTHER
msgid "Defeat the King of Nothing."
msgstr "Здолати Короля Нічого"

#: .uk.INFINITETOWER_WAVE_DESCRIPTION_BOSS_SCAV
msgid "A taste of your own medicine."
msgstr "Такий, як ти."

#: .uk.ITWAVE_DESC_BASIC_ENIGMA
msgid "Your equipment changes every time it's activated."
msgstr "Ваше спорядження змінюється після кожної активації."

#: .uk.ITWAVE_DESC_BASIC_KIN
msgid "Monsters will be of only one type."
msgstr "Монстри будуть лиш одного типу."

#: .uk.ITWAVE_NAME_BASIC_EVOLUTION
msgid "Wave {0} - Augment of Evolution"
msgstr "Хвиля {0} - Вкраплення еволюції"

#: .uk.ITWAVE_DESC_BASIC_EVOLUTION
msgid "Monsters have additional items during this wave."
msgstr "Протягом цієї хвилі монстри матимуть додаткові предмети."

#: .uk.ITWAVE_NAME_BASIC_SACRIFICE
msgid "Wave {0} - Augment of Sacrifice"
msgstr "Хвиля {0} - Вкраплення жертвоприношення"

#: .uk.ITWAVE_DESC_BASIC_SACRIFICE
msgid "Monsters have a chance to drop items on death."
msgstr "З монстрів після смерті іноді падають предмети."

#: .uk.ITWAVE_NAME_BASIC_METAMORPH
msgid "Wave {0} - Augment of Metamorphosis"
msgstr "Хвиля {0} - Вкраплення метаморфозу"

#: .uk.ITWAVE_DESC_BASIC_METAMORPH
msgid "Play as a random survivor for this wave."
msgstr "Протягом цієї хвилі ви граєте за випадкового вцілілого."

#: .uk.ITWAVE_NAME_BASIC_HONOR
msgid "Wave {0} - Augment of Honor"
msgstr "Хвиля {0} - Вкраплення честі"

#: .uk.ITWAVE_DESC_BASIC_HONOR
msgid "Enemies are guaranteed to be Elite."
msgstr "Тільки елітні вороги."

#: .uk.ITWAVE_NAME_BASIC_SWARMS
msgid "Wave {0} - Augment of Swarms"
msgstr "Хвиля {0} - Вкраплення рою"

#: .uk.ITWAVE_NAME_BASIC_HONORBRIGADE
msgid "Wave {0} - Augment of Brigade and Honor"
msgstr "Хвиля {0} - Вкраплення загону честі"

#: .uk.ITWAVE_DESC_BASIC_HONORBRIGADE
msgid "All enemies are elite and the same elite type."
msgstr "Тільки елітні вороги однакового елітного типу."

#: .uk.ITWAVE_NAME_BASIC_DEVOTION
msgid "Wave {0} - Augment of Devotion"
msgstr "Хвиля {0} - Вкраплення відданості"

#: .uk.ITWAVE_DESC_BASIC_DEVOTION
msgid "Lemurian Eggs appear. Hatch them with an item."
msgstr "З'являються яйця лемуріанців. Дайте їм предмет, щоб вилупити."

#: .uk.ITWAVE_NAME_BASIC_DELUSION
msgid "Wave {0} - Augment of Delusion"
msgstr "Хвиля {0} - Вкраплення омани"

#: .uk.ITWAVE_DESC_BASIC_DELUSION
msgid "Risk your items on previously opened chests in a test of memory"
msgstr ""
"Перевірте вашу пам'ять у відкритих скринях, щоб отримати більше предметів"

#: .uk.ITWAVE_NAME_BOSS_HONOR
msgid "Wave {0} - Boss Augment of Honor"
msgstr "Хвиля {0} - Бос, вкраплення of Honor"

#: .uk.ITWAVE_DESC_BOSS_HONOR
msgid "Enemies are stronger and guaranteed to be Elite."
msgstr "Тільки елітні, сильніші вороги."

#: .uk.ITWAVE_NAME_BOSS_VENGENCE
msgid "Wave {0} - Boss Augment of Vengeance"
msgstr "Хвиля {0} - Бос, вкраплення помсти"

#: .uk.ITWAVE_DESC_BOSS_VENGENCE
msgid "Your relentless doppelganger invades."
msgstr "З'являється ваш нещадний двійник."

#: .uk.ITWAVE_NAME_BOSS_KIN
msgid "Wave {0} - Boss Augment of Kin"
msgstr "Хвиля {0} - Бос, вкраплення спорідненості"

#: .uk.ITWAVE_DESC_BOSS_KIN
msgid "Defeat a horde of many of the same monster."
msgstr "Здолайте орду однакових монстрів."

#: .uk.ITWAVE_NAME_BOSS_DISSONANCE
msgid "Wave {0} - Boss Augment of Dissonance"
msgstr "Хвиля {0} - Бос, вкраплення дисонансу"

#: .uk.ITWAVE_DESC_BOSS_DISSONANCE
msgid "Enemies are stronger and appear outside their usual environments."
msgstr "Вороги сильніше, і з'являються за межами свого звичайного середовища."

#: .uk.ITWAVE_NAME_BOSS_DISSOFAKE
msgid "Wave {0} - Boss Augment of True Dissonance"
msgstr "Хвиля {0} - Бос, вкраплення істинного дисонансу"

#: .uk.ITWAVE_DESC_BOSS_DISSOFAKE
msgid "All enemies are allowed to spawn."
msgstr "З'являються всі вороги."

#: .uk.ITWAVE_NAME_BOSS_ARTIFACTS
msgid "Wave {0} - Boss Augment of Artifacts"
msgstr "Хвиля {0} - Бос, вкраплення артефактів"

#: .uk.ITWAVE_DESC_BOSS_ARTIFACTS
msgid "2 random Artifacts are enabled."
msgstr "Увімкнено два випадкових артефакти."

#: .uk.ITWAVE_NAME_BASIC_VOIDBEAR
msgid "Wave {0} - Augment of Safety"
msgstr "Хвиля {0} - Вкраплення безпеки"

#: .uk.ITWAVE_DESC_BASIC_VOIDBEAR
msgid "Enemies block the first multiple instances of damage."
msgstr "Вороги блокують перші декілька ударів."

#: .uk.ITWAVE_NAME_BASIC_BLIND
msgid "Wave {0} - Augment of Blindness"
msgstr "Хвиля {0} - Вкраплення сліпоти"

#: .uk.ITWAVE_DESC_BASIC_BLIND
msgid "It becomes hard to see."
msgstr "Стає складно бачити."

#: .uk.ITWAVE_NAME_BASIC_SLIPPERY
msgid "Wave {0} - Augment of Friction"
msgstr "Хвиля {0} - Вкраплення тертя"

#: .uk.ITWAVE_DESC_BASIC_SLIPPERY
msgid "The ground turns slippery."
msgstr "Земля стає слизькою."

#: .uk.ITWAVE_NAME_BASIC_BADLUCK
msgid "Wave {0} - Augment of Misfortune"
msgstr "Хвиля {0} - Вкраплення невдачі"

#: .uk.ITWAVE_DESC_BASIC_BADLUCK
msgid "Your luck is decreased for the current wave."
msgstr "Протягом цієї хвилі, ваша удача зменшена."

#: .uk.ITWAVE_NAME_BASIC_NOCOOLDOWN
msgid "Wave {0} - Augment of Frenzy"
msgstr "Хвиля {0} - Вкраплення безумства"

#: .uk.ITWAVE_DESC_BASIC_NOCOOLDOWN
msgid "Skills have no cooldowns."
msgstr "Здібності вмить перезаряджаються."

#: .uk.ITWAVE_NAME_BASIC_TONIC
msgid "Wave {0} - Augment of Tonic"
msgstr "Хвиля {0} - Вкраплення тоніку"

#: .uk.ITWAVE_DESC_BASIC_TONIC
msgid "Monsters have a short stat boost and are crippled afterwards."
msgstr ""
"Монстри отримують тимчасове посилення всіх характеристик, але опісля "
"страждають від ломки."

#: .uk.ITWAVE_NAME_BOSS_LEECH
msgid "Wave {0} - Boss Augment of Leeching"
msgstr "Хвиля {0} - Бос, вкраплення кровосісі"

#: .uk.ITWAVE_DESC_BOSS_LEECH
msgid "Monsters heal on hit and have increased healing."
msgstr "Монстри зцілюються, коли завдають шкоди та зцілюються більш ефективно."

#: .uk.ITWAVE_NAME_BASIC_SULFURPODS
msgid "Wave {0} - Augment of Sulfur"
msgstr "Хвиля {0} - Вкраплення сірки"

#: .uk.ITWAVE_DESC_BASIC_SULFURPODS
msgid "Sulfur pods keep growing."
msgstr "Розростаються сірчані бутони."

#: .uk.ITWAVE_NAME_BASIC_TARPOTS
msgid "Wave {0} - Augment of Tar"
msgstr "Хвиля {0} - Вкраплення Дьогтю"

#: .uk.ITWAVE_DESC_BASIC_TARPOTS
msgid "It's raining pots of tar."
msgstr "Дощить глечиками з Дьогтем."

#: .uk.ITWAVE_NAME_BASIC_LUNARELITE
msgid "Wave {0} - Augment of Perfection"
msgstr "Хвиля {0} - Вкраплення бездоганності"

#: .uk.ITWAVE_DESC_BASIC_LUNARELITE
msgid "Elites spawn as Perfected."
msgstr "Всі еліти стають бездоганними."

#: .uk.ITWAVE_NAME_BASIC_VOIDELITE
msgid "Wave {0} - Augment of Collapse"
msgstr "Хвиля {0} - Вкраплення колапсу"

#: .uk.ITWAVE_DESC_BASIC_VOIDELITE
msgid "Elites spawn as Voidtouched."
msgstr "Еліт торкнулась Порожнеча."

#: .uk.ITWAVE_NAME_BOSS_LUNARVOIDELITE_PRECOLOR
msgid "Wave {0} - Boss Augment of Duality"
msgstr "Хвиля {0} - Бос, вкраплення двоїстості"

#: .uk.ITWAVE_NAME_BOSS_LUNARVOIDELITE
msgid ""
"<color=#6EB5F5>Wave {0}</color><color=#8CA9EB> - Boss</color><color=#AB9DE1> "
"Augme</color><color=#CA92D7>nt of </color><color=#E987CE>Duality</color>"
msgstr ""
"<color=#6EB5F5>Хвиля {0}</color><color=#8CA9EB> - Бос,</color>"
"<color=#AB9DE1> вкрап</color><color=#CA92D7>лення </color><color=#E987CE>"
"двоїстості</color>"

#: .uk.ITWAVE_DESC_BOSS_LUNARVOIDELITE
msgid "Elites spawn as Perfected or Voidtouched."
msgstr "З'являються або бездоганні еліти, або еліти Порожнечі."

#: .uk.ITWAVE_NAME_BASIC_FLYING
msgid "Wave {0} - Augment of Flight"
msgstr "Хвиля {0} - Вкраплення польоту"

#: .uk.ITWAVE_DESC_BASIC_FLYING
msgid "All enemies gain flight."
msgstr "Усі вороги здатні літати."

#: .uk.ITWAVE_NAME_BASIC_MALACHITE
msgid "Wave {0} - Augment of Malachite"
msgstr "Хвиля {0} - Вкраплення малахіту"

#: .uk.ITWAVE_DESC_BASIC_MALACHITE
msgid "All enemies spawn as weakened Malachites."
msgstr "Усі вороги стають послабленими малахітовими елітами."

#: .uk.ITWAVE_NAME_BASIC_BATTERY
msgid "Wave {0} - Augment of Battery"
msgstr "Хвиля {0} - Вкраплення батареї"

#: .uk.ITWAVE_DESC_BASIC_BATTERY
msgid "Improper storage may cause serious harm."
msgstr "Неналежне зберігання може обернутись катастрофічними наслідками."

#: .uk.ITWAVE_NAME_BASIC_GOOBO
msgid "Wave {0} - Augment of Gummy"
msgstr "Хвиля {0} - Вкраплення полімеризації"

#: .uk.ITWAVE_DESC_BASIC_GOOBO
msgid "Monsters spawn gummy clones."
msgstr "Вороги створюють полімерних клонів."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_BEETLE
msgid "Wave {0} - Augment of Beetle"
msgstr "Хвиля {0} - Вкраплення жуків"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_BEETLE
msgid "The ground begins to shift beneath you."
msgstr "Земля втікає з-під ніг."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_GOLEM
msgid "Wave {0} - Augment of Earth"
msgstr "Хвиля {0} - Вкраплення землі"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_GOLEM
msgid "The earth rumbles and groans."
msgstr "Земля гуде і стогне."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_JELLYFISH
msgid "Wave {0} - Augment of the Jellyfish"
msgstr "Хвиля {0} - Вкраплення медуз"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_JELLYFISH
msgid "The air crackles and arcs."
msgstr "Повітря потріскує і виблискує дугами."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_WISP
msgid "Wave {0} - Augment of Embers"
msgstr "Хвиля {0} - Вкраплення іскор"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_WISP
msgid "The air begins to burn."
msgstr "Повітря починає палати."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_LEMURIAN
msgid "Wave {0} - Augment of Lemuria"
msgstr "Хвиля {0} - Вкраплення Лемурії"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_LEMURIAN
msgid "The ground's temperature begins to rise."
msgstr "Температура ґрунту починає зростати."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_IMP
msgid "Wave {0} - Augment of the Red Plane"
msgstr "Хвиля {0} - Вкраплення Червоного виміру"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_IMP
msgid "A tear in the fabric of the universe."
msgstr "Розрив у тканині світобудови."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_GUP
msgid "Wave {0} - Augment of Gup"
msgstr "Хвиля {0} - Вкраплення ґапів"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_GUP
msgid "The air smells of sweet strawberries."
msgstr "Повітря пахне солодкими полуницями."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_CONSTRUCT
msgid "Wave {0} - Augment of the Constructs"
msgstr "Хвиля {0} - Вкраплення конструкцій"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_CONSTRUCT
msgid "You have tripped an ancient alarm."
msgstr "Вас засікла старовинна система охорони."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_PARENT
msgid "Wave {0} - Augment of Parenthood"
msgstr "Хвиля {0} - Вкраплення батьківства"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_PARENT
msgid "A familial bond is being interrupted."
msgstr "Родинний зв'язок переривається."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_LARVA
msgid "Wave {0} - Augment of Acid"
msgstr "Хвиля {0} - Вкраплення кислоти"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_LARVA
msgid "The air smells foul."
msgstr "Повітря неприємно пахне."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_MUSHROOM
msgid "Wave {0} - Augment of Mushrooms"
msgstr "Хвиля {0} - Вкраплення грибів"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_MUSHROOM
msgid "The ground grows sickly."
msgstr "Земля заростає хворобою."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_LUNAR
msgid "Wave {0} - Augment of the Moon"
msgstr "Хвиля {0} - Вкраплення Місяця"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_LUNAR
msgid "The bulwark begin to falter."
msgstr "Оплот починає хитатися."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_VOID
msgid "Wave {0} - Augment of the Void"
msgstr "Хвиля {0} - Вкраплення Порожнечі"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_VOID
msgid "The Void has become curious."
msgstr "Порожнеча зацікавилася вами."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_CLAY
msgid "Wave {0} - Augment of Aphelia"
msgstr "Хвиля {0} - Вкраплення Афелії"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_CLAY
msgid "You feel parasitic influences."
msgstr "Ви відчуваєте паразитичний вплив."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_SOLUS
msgctxt ".uk.ITWAVE_NAME_BASIC_FAMILY_SOLUS"
msgid "Wave {0} - Augment of Solus X"
msgstr "Хвиля {0} - Вкраплення Солус Х"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_SOLUS
msgid "The whirring of wings and machinery."
msgstr "Дзижчання крил та машинерії."

#: .uk.ITWAVE_NAME_BASIC_FAMILY_VERMIN
msgid "Wave {0} - Augment of Vermin"
msgstr "Хвиля {0} - Вкраплення гадів"

#: .uk.ITWAVE_DESC_BASIC_FAMILY_VERMIN
msgid "You have invaded rampant breeding grounds."
msgstr "Ви вторглись у клекотливий розплідник."

#: .uk.ITWAVE_NAME_BOSS_FAMILY_WORM
msgid "Wave {0} - Boss Augment of Wurms"
msgstr "Хвиля {0} - Бос, вкраплення зміїв"

#: .uk.ITWAVE_DESC_BOSS_FAMILY_WORM
msgid "His brother loved worms."
msgstr "Його брат любив хробаків."

#: .uk.ITWAVE_NAME_BOSS_FAMILY_BOSS
msgid "Wave {0} - Boss Augment of Champions"
msgstr "Хвиля {0} - Бос, вкраплення чемпіонів"

#: .uk.ITWAVE_DESC_BOSS_FAMILY_BOSS
msgid "Only boss monsters spawn."
msgstr "Тільки вороги-боси."

#: .uk.ITWAVE_NAME_BOSS_FAMILY_DRONES
msgid "Wave {0} - Boss Augment of the Machines"
msgstr "Хвиля {0} - Бос, вкраплення машин"

#: .uk.ITWAVE_DESC_BOSS_FAMILY_DRONES
msgid "Drones and machines fight against you."
msgstr "Проти вас б'ються дрони й машини."

#: .uk.ITWAVE_NAME_BASIC_DEATHLUNAR
msgid "Wave {0} - Augment of Blaze"
msgstr "Хвиля {0} - Вкраплення спалаху"

#: .uk.ITWAVE_DESC_BASIC_DEATHLUNAR
msgid "The ground gets covered in lunar flames."
msgstr "Земля вкрита місячним полум'ям."

#: .uk.ITWAVE_NAME_BASIC_DEATHVOID
msgid "Wave {0} - Augment of Implosion"
msgstr "Хвиля {0} - Вкраплення краху"

#: .uk.ITWAVE_DESC_BASIC_DEATHVOID
msgid "Endless void implosions occur."
msgstr "Відбуваються постійні вибухи Порожнечі."

#: .uk.ITWAVE_NAME_BASIC_DEATHHEALING
msgid "Wave {0} - Augment of Mending"
