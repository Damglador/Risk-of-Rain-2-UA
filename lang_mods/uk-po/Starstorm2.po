"<style=cIsUtility>50%</style> під час <color=#FFCCED>штормів/бурь тощо</"
"color>."

#: .uk.SS2_ITEM_MOXIE_PICKUP
msgid "<color=#FFCCED>How much more?</color>"
msgstr "<color=#FFCCED>Скільки ще?</color>"

#: .uk.SS2_ITEM_MOXIE_LORE
