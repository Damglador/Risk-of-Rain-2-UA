#: .strings.SS2_ITEM_NKOTASHERITAGE_NAME
msgid "Nkota's Heritage"
msgstr "Спадщина Нкоти"

#: .strings.SS2_ITEM_NKOTASHERITAGE_DESC
msgid ""
"Receive <style=cIsUtility>{0}</style> <style=cStack>(+{0} per stack)</style> "
"<style=cIsUtility>items</style> upon level up. Rarity of items increases "
