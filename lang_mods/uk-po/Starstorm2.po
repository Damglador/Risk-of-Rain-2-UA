"Carry up to three stacks of Fortified, <style=cIsUtility>increasing armor by "
"100</style> as long as at least one stack is held. Lose a stack when "
"<style=cIsHealth>damaged</style>. Regain 2 stacks after a "
"<style=cIsUtility>succcesful parry</style>."
msgstr ""

#: .uk.SS2_KNIGHT_PRIMARY_SWORD_NAME
msgid "Duel"
msgstr ""

#: .uk.SS2_KNIGHT_PRIMARY_SWORD_DESC
msgid "Slice in front for <style=cIsDamage>240% damage</style>."
msgstr ""

#: .uk.SS2_KEYWORD_PARRY
