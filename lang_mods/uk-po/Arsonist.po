#: .strings.POPCORN_ARSONIST_BODY_PASSIVE_NAME
msgid "Pyromania"
msgstr "Піроманія"

#: .strings.POPCORN_ARSONIST_BODY_PASSIVE_DESCRIPTION
msgid ""
"Resist fire damage from all sources. Convert one attack dealing greater than "
"<style=cIsDamage>30%</style> of total health into <style=cIsDamage>50%</"
"style> fire damage over time."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_NAME
msgid "Normal Gauge"
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_PASSIVE_NORMAL_GAUGE_DESCRIPTION
msgid ""
"Deal <style=cIsDamage>100%</style> damage in white portion. Base Gauge is "
"resistant to Overheating."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_NAME
msgid "Supercritical Gauge"
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_PASSIVE_BLUE_GAUGE_DESCRIPTION
msgid ""
"Deal <style=cIsDamage>70%</style> damage in white portion, deal "
"<style=cIsDamage>250%</style> damage in blue portion. Maximum heat is fixed."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_NAME
msgid "Fireball"
msgstr "Вогнекуля"

#: .strings.POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_DESCRIPTION
msgid ""
"<style=cIsUtility>Heat. </style>Fire a ball of fire that deals "
"<style=cIsDamage>225% damage and ignites</style> enemies on hit. "
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_ALT_PRIMARY_FIRESPRAY_NAME
msgid "Overdrive"
msgstr "Розгін"

#: .strings.POPCORN_ARSONIST_BODY_ALT_PRIMARY_FIRESPRAY_DESCRIPTION
msgid ""
"<style=cIsUtility>Heat. </style><style=cIsUtility>Supercritical. </"
"style>Fire a ball of fire that deals <style=cIsDamage>160% damage and "
"ignites</style> enemies on hit. "
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_NAME
msgid "Dragon's Breath"
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_DESCRIPTION
msgid ""
"Fire a beam of fire that deals <style=cIsDamage>90%</style> damage. Has "
"increased chance to ignite the closer you are to the target."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_SCEPTER_NAME
msgid "Firestorm"
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_PRIMARY_FIRESPRAY_SCEPTER_DESCRIPTION
msgid ""
"<style=cIsUtility>Heat. </style>Fire a piercing beam of intense heat that "
"deals <style=cIsDamage>300% damage and ignites</style> enemies on hit.If "
"held held for short time, fire a destructive beam that deals "
"<style=cIsDamage>450% damage</style> when released."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_NAME
msgid "Dante's Rebuke"
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_PRIMARY_FLAMETHROWER_SCEPTER_DESCRIPTION
msgid ""
"Fire an intense beam that deals <style=cIsDamage>140% damage.</style> Has "
"increased chance to ignite the closer you are to the target. If held for 2 "
"seconds or more, Fire a final beam on release for <style=cIsDamage>150% "
"damage.</style> "
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_NAME
msgid "Signal Flare"
msgstr "Сигнальний вогонь"

#: .strings.POPCORN_ARSONIST_BODY_SECONDARY_FLAREGUN_DESCRIPTION
msgid ""
"Fire a flare that deals <style=cIsDamage>400%</style> damage over 5 seconds, "
"then explodes for <style=cIsDamage>400%</style> damage, launching 5 flares "
"that deal <style=cIsDamage>200%</style> damage each. "
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_NAME
msgid "Zero Point Blast"
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_SECONDARY_PUNCH_DESCRIPTION
msgid ""
"<style=cIsUtility>Agile. Heat. </style>Propel yourself forwards, blasting "
"enemies behind you for <style=cIsDamage>200% damage</style>. Colliding "
"shortly after launching into the first enemy and deals <style=cIsDamage>200% "
"damage</style> in a blast around you. "
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_UTILITY_CLEANSE_NAME
msgid "Cleanse"
msgstr "Очищення"

#: .strings.POPCORN_ARSONIST_BODY_UTILITY_CLEANSE_DESCRIPTION
msgid ""
"<style=cIsUtility>Agile. Heat. </style><style=cIsDamage>Ignite</style> the "
"area around you, dealing <style=cIsDamage>50%</style> to enemies around you "
"and burning away other status effects. Grants a small boost of speed. "
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_NAME
msgctxt ".strings.POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_NAME"
msgid "Masochism"
msgstr "Мазохізм"

#: .strings.POPCORN_ARSONIST_BODY_SPECIAL_MASOCHIST_DESCRIPTION
msgid ""
"<style=cIsUtility>Agile. Heat. </style>Damage from being "
"<style=cIsDamage>Ignited</style> turns into <style=cIsHealing>healing</"
"style> for 6.5 seconds. Increases attack speed <style=cIsDamage>125%</style>."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_NAME
msgctxt ".strings.POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_NAME"
msgid "Masochism"
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_DESCRIPTION
msgid ""
"Upon reaching the <color=#FF9402>Anticipation</color> threshold, "
"periodically damage yourself in exchange for area of effect burning "
"<color=#9FFF02>Lifesteal</color>. After a maximum of 10 seconds, "
"<style=cIsDamage>Detonate</style>, then <color=#E40000>Overheat</color>."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_NAME
msgid "Spite"
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_SPECIAL_MASOCHISM_SURGE_DESCRIPTION
msgid ""
"Upon reaching the <color=#FF9402>Anticipation</color> threshold, you move "
"faster, and are granted <color=#FF9402>Double Tap</color> and "
"<color=#9FFF02>Lifesteal</color>. After a maximum of 10 seconds, "
"<style=cIsDamage>Detonate</style>, then <color=#E40000>Overheat</color>."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_PASSIVE
msgid ""
"<style=cKeywordName>Heat</style>Skills increase/decrease heat. At max heat, "
"arsonist overheats, weakening their skills and causing longer cooldowns. "
"Attack speed increases cooling rate. The selected primary chosen alters the "
"heat gauge. "
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_BASEGAUGE
msgid ""
"<style=cKeywordName>Base Gauge</style>Heat gauge increase per level as well "
"as with stock-based items. Cooling rate also increases at higher %s of heat."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_CRITICALGAUGE
msgid ""
"<style=cKeywordName>Supercritical Gauge</style>Heat gauge does not increase, "
"instead supercritical gauge increases per level as well as with stock-based "
"items. Gain 2.5x damage while heat is in the blue portion of the gauge. "
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_FIRESPRAYHEAT
msgid ""
"<style=cKeywordName>Heat</style>Costs <style=cIsDamage>10 heat</style>. "
"Reduced damage and speed in overheat."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_PRIMARYHEAT
msgid ""
"<style=cKeywordName>Heat</style>Primary fire raises heat, all other skills "
"lower heat. At maximum heat, Arsonist Overheats, reducing attack speed and "
"damage temporarily."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_FLAREHEAT
msgid ""
"<style=cKeywordName>Heat</style>Reduces Heat by <style=cIsDamage>0.3x</"
"style> of current heat accumulated. Half damage in overheat."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_ZEROPOINTHEAT
msgid ""
"<style=cKeywordName>Heat</style>Cools <style=cIsUtility>half of CURRENT "
"heat</style>. Half damage in overheat."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_CLEANSEHEAT
msgid ""
"<style=cKeywordName>Heat</style>Cools <style=cIsUtility>half of TOTAL heat</"
"style>. Accelerates cooling in overheat, however, no ignite."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_MASOCHISMHEAT
msgid ""
"<style=cKeywordName>Heat</style>Costs <style=cIsDamage>50 heat</style>. Half "
"healing in overheat."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_FLARENOTE
msgid ""
"The flare won't split unless it hits a target, is stepped on or an enemy is "
"hit by the blast."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_PYROMANIAPASSIVE
msgid "Pyromania does not affect fall damage unless Frailty is active."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_BASEGAUGEPASSIVE
msgid ""
"Stock-based items increase maximum heat. Increasing attack speed increases "
"heat dissipation."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_SUPERCRITICALPASSIVE
msgid ""
"Stock-based items increase blue portion. Increasing attack speed increases "
"heat dissipation."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_MASO_ANTICIPATION
msgid ""
"<style=cKeywordName>Anticipation</style>For every 100 heat lost and/or "
"gained, Arsonist gains 1 stack of Anticipation; After gaining 5 stacks, he "
"may activate Masochism; Additional stacks increase damage and duration; All "
"stacks are exhausted at the end."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_MASO_ANTICIPATION_SPITE
msgid ""
"<style=cKeywordName>Anticipation</style>For every 100 heat lost and/or "
"gained, Arsonist gains 1 stack of Anticipation; After gaining 5 stacks, he "
"may activate Spite. Additional stacks increase damage and duration. The "
"amount of stacks removed at the end correlates with how long you stay in the "
"state."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_MASO_LIFESTEAL
msgid ""
"<style=cKeywordName>Lifesteal</style>Arsonist heals <color=#9FFF02>18%</"
"color> of his damage dealt while Masochism is active."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_MASO_SURGE_LIFESTEAL
msgid ""
"<style=cKeywordName>Lifesteal</style>Arsonist heals <color=#9FFF02>5%</"
"color> of his damage dealt while Masochism is active."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_MASO_DETONATE
msgid ""
"<style=cKeywordName>Detonate</style>Arsonist explodes, dealing "
"<style=cIsDamage>150% damage</style> times the amount of Anticipation Stacks "
"accumulated."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_MASO_DETONATE_SPITE
msgid ""
"<style=cKeywordName>Detonate</style>Arsonist explodes, dealing "
"<style=cIsDamage>70% damage</style> times the amount of Anticipation Stacks "
"accumulated."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_MASO_DOUBLE_TAP
msgid ""
"<style=cKeywordName>Double Tap</style>Shoot two projectiles for the heat "
"cost of one."
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_KEYWORD_OVERHEAT_MASO
msgid ""
"<style=cKeywordName>Overheat: Masochism</style>If Arsonist exits Masochism "
"due to too much heat buildup, EX Overheat is applied, reducing your Move "
"Speed and Damage to 70%. Cancelling, or otherwise letting the move run it's "
"course applies Overheat, reducing your Attack speed to 50%"
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_OVERHEAT_TEXT
msgid "OVERHEAT!"
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_OVERHEAT_EX_TEXT
msgid "OVERHEAT:EX!"
msgstr ""

#: .strings.POPCORN_ARSONIST_BODY_COOLING_TEXT
msgid "COOLING...!"
msgstr ""

