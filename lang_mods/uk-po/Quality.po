"<style=cIsVoid>Void</style>. <sprite name=\"Quality\"> Increase spawn rate "
"and <style=cIsVoid>Void ally</style> damage. <style=cIsVoid>Corrupts all </"
"style><style=cIsTierBoss>yellow items</style><style=cIsVoid></style>."
msgstr ""
