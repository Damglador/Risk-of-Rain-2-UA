"<style=cStack>(+2.4m per stack)</style> radius burst for "
"<style=cIsDamage>260%</style> <style=cStack>(+156% per stack)</style> base "
"damage plus <sprite name=\"Quality\"> <style=cIsDamage>50%</style> "
"<style=cStack>(+50% per stack)</style> TOTAL damage. <style=cIsVoid>Corrupts "
"all Will-o'-the-wisps</style>."
msgstr ""
