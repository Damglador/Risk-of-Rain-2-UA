#: .uk.ITEM_JUMPBOOST_UNCOMMON_PICKUP
msgctxt ".uk.ITEM_JUMPBOOST_UNCOMMON_PICKUP"
msgid ""
"{0}\n"
"<sprite name=\"Quality\"> Increase speed when chaining jumps."
msgstr ""
"{0}\n"
"<sprite name=\"Quality\"> Пришвидшує стрибки, якщо не припиняти стрибати."

#: .uk.ITEM_JUMPBOOST_UNCOMMON_DESC
msgid ""
"{0}\n"
"<style=cIsUtility>Chained</style> jumps increase speed by <sprite "
"name=\"Quality\"> <style=cIsUtility>20%</style> <style=cStack>(+20% per "
"stack)</style> per jump, up to a maximum of <sprite name=\"Quality\"> "
"<style=cIsUtility>100%</style> <style=cStack>(+100% per stack)</style>."
msgstr ""
"{0}\n"
