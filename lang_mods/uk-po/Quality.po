msgid ""
"{0}\n"
"<sprite name=\"Quality\"> Chance to reduce skill cooldowns on kill."
msgstr ""
"{0}\n"
"<sprite name=\"Quality\"> Інколи скорочує час перезаряджання здібностей "
"після вбивства."

#: .uk.ITEM_ALIENHEAD_UNCOMMON_DESC
msgid ""
"{0}\n"
"<sprite name=\"Quality\"> <style=cIsUtility>15%</style> <style=cStack>(+15% "
